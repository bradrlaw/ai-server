# Whitelist repo: ignore everything at the root by default, then re-include only
# the things we want tracked (docs, scripts, and base project files). Large/local
# artifacts (models, venvs, source checkouts, datasets, service data) stay local.
/*

# --- tracked top-level paths ---
!/.gitignore
!/README.md
!/AGENTS.md
!/LICENSE
!/docs/
!/scripts/
!/docker/
!/config/

# --- drop generated/cache files inside tracked dirs ---
__pycache__/
*.pyc
*.pyo

# --- llama-swap active config is GENERATED from the base + a mode overlay ---
# (scripts/llama-swap-mode.py). The canonical source is config/llama-swap.base.yaml
# (tracked); the rendered active file the service reads is runtime state, so ignore
# it to avoid churn on every mode switch. Regenerate with: llama-swap-mode.py set <mode>
/config/llama-swap.yaml

# --- never commit secrets/local env ---
*.env
.env
*.key
*.pem
*_token
*.secret

# --- ComfyUI MCP workflows: opt-in tracking only (per @bradrlaw) ---
# New workflow files may contain private prompts/paths, so ignore this directory's
# contents by default and re-include ONLY the workflows explicitly meant to be
# shared. To publish a new workflow, add a matching '!' line below.
/config/comfyui-mcp/workflows/*
!/config/comfyui-mcp/workflows/flux1_krea.json
!/config/comfyui-mcp/workflows/flux1_krea.meta.json
!/config/comfyui-mcp/workflows/flux2_klein.json
!/config/comfyui-mcp/workflows/flux2_klein.meta.json
!/config/comfyui-mcp/workflows/generate_image.json
!/config/comfyui-mcp/workflows/generate_song.json
!/config/comfyui-mcp/workflows/z_image_turbo.json
!/config/comfyui-mcp/workflows/z_image_turbo.meta.json
