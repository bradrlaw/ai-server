# Whitelist repo: ignore everything at the root by default, then re-include only
# the things we want tracked (docs, scripts, and base project files). Large/local
# artifacts (models, venvs, source checkouts, datasets, service data) stay local.
/*

# --- tracked top-level paths ---
!/.gitignore
!/README.md
!/AGENTS.md
!/LICENSE
!/docs/
!/scripts/
!/docker/
!/config/

# --- drop generated/cache files inside tracked dirs ---
__pycache__/
*.pyc
*.pyo

# --- never commit secrets/local env ---
*.env
.env
*.key
*.pem
*_token
*.secret

# --- local-only ComfyUI MCP workflows (kept on the box, never tracked) ---
/config/comfyui-mcp/workflows/krea2_turbo.json
/config/comfyui-mcp/workflows/krea2_turbo.meta.json
/config/comfyui-mcp/workflows/krea2_turbo_bf16.json
/config/comfyui-mcp/workflows/krea2_turbo_bf16.meta.json
