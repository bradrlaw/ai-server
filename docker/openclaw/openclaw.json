// OpenClaw personal-assistant gateway config (canonical, generated by
// `openclaw onboard --non-interactive` then patched with the model roster).
// Tracked TEMPLATE — assistants-seed.sh copies it to
// /srv/ai/openclaw/state/openclaw.json (gitignored, writable). No secrets:
// apiKey + gateway token are ENV REFERENCES (LITELLM_API_KEY / OPENCLAW_GATEWAY_TOKEN,
// supplied by the compose service). Models are served by the native llama-swap
// router behind LiteLLM on the host (:4000), reached via host.docker.internal.
{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "litellm/chat",
        "fallbacks": [
          "litellm/coding"
        ]
      },
      "models": {
        "litellm/chat": {},
        "litellm/coding": {},
        "litellm/fast": {}
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": {
        "source": "env",
        "provider": "default",
        "id": "OPENCLAW_GATEWAY_TOKEN"
      }
    },
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "allowInsecureAuth": true
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "update": {
    "checkOnStart": false
  },
  "tools": {
    "profile": "coding"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "litellm": {
        "baseUrl": "http://host.docker.internal:4000/v1",
        "api": "openai-completions",
        "apiKey": "${LITELLM_API_KEY}",
        "models": [
          {
            "id": "chat",
            "name": "Qwen3.6-35B-A3B (chat)",
            "contextWindow": 262144,
            "maxTokens": 32768,
            "input": [
              "text"
            ],
            "reasoning": true
          },
          {
            "id": "coding",
            "name": "Qwen3.6-27B (coding)",
            "contextWindow": 204800,
            "maxTokens": 32768,
            "input": [
              "text"
            ],
            "reasoning": true
          },
          {
            "id": "fast",
            "name": "Gemma-4-12B (fast)",
            "contextWindow": 131072,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "reasoning": false
          }
        ]
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    },
    "allowBundled": [
      "browser-automation",
      "canvas",
      "clawhub",
      "diagram-maker",
      "gh-issues",
      "github",
      "healthcheck",
      "meme-maker",
      "node-connect",
      "node-inspect-debugger",
      "notion",
      "python-debugpy",
      "session-logs",
      "skill-creator",
      "spike",
      "taskflow",
      "taskflow-inbox-triage",
      "video-frames",
      "weather"
    ],
    "entries": {
      "1password": { "enabled": false },
      "apple-notes": { "enabled": false },
      "apple-reminders": { "enabled": false },
      "bear-notes": { "enabled": false },
      "blogwatcher": { "enabled": false },
      "blucli": { "enabled": false },
      "camsnap": { "enabled": false },
      "coding-agent": { "enabled": false },
      "eightctl": { "enabled": false },
      "gemini": { "enabled": false },
      "gifgrep": { "enabled": false },
      "gog": { "enabled": false },
      "goplaces": { "enabled": false },
      "himalaya": { "enabled": false },
      "mcporter": { "enabled": false },
      "model-usage": { "enabled": false },
      "nano-pdf": { "enabled": false },
      "obsidian": { "enabled": false },
      "openai-whisper": { "enabled": false },
      "openai-whisper-api": { "enabled": false },
      "openhue": { "enabled": false },
      "oracle": { "enabled": false },
      "ordercli": { "enabled": false },
      "peekaboo": { "enabled": false },
      "sag": { "enabled": false },
      "sherpa-onnx-tts": { "enabled": false },
      "songsee": { "enabled": false },
      "sonoscli": { "enabled": false },
      "spotify-player": { "enabled": false },
      "summarize": { "enabled": false },
      "things-mac": { "enabled": false },
      "tmux": { "enabled": false },
      "trello": { "enabled": false },
      "xurl": { "enabled": false }
    }
  }
}
