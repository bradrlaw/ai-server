# Secrets for the docker app tier. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real keys.

# LiteLLM gateway master key. Clients (Copilot CLI, VS Code, Open WebUI, OpenClaw)
# authenticate with this as their OpenAI API key. Generate a strong one, e.g.:
#   printf 'sk-%s\n' "$(head -c 32 /dev/urandom | base64 | tr -dc 'A-Za-z0-9' | head -c 40)"
LITELLM_MASTER_KEY=sk-REPLACE_ME

# Open WebUI session signing secret. Generate like the master key above.
WEBUI_SECRET_KEY=REPLACE_ME
# SearXNG secret_key (substituted into searxng/settings.yml at container start).
SEARXNG_SECRET=REPLACE_ME
# mcpo API key — clients (Open WebUI OpenAPI tool servers) send this as a bearer token.
MCPO_API_KEY=sk-mcpo-REPLACE_ME

# --- Assistant gateways (OpenClaw + Hermes) ---
# OpenClaw gateway auth token (required for LAN bind). Generate:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME
# Hermes web dashboard (:9119) basic auth. Username defaults to "admin".
HERMES_DASHBOARD_USER=admin
HERMES_DASHBOARD_PASSWORD=REPLACE_ME
# Hermes OpenAI-compatible API server (:8642) key (min 8 chars). Generate:
#   openssl rand -hex 32
HERMES_API_SERVER_KEY=REPLACE_ME
# Both gateways authenticate to LiteLLM with LITELLM_MASTER_KEY above
# (OpenClaw maps it to LITELLM_API_KEY; Hermes' key is injected into its config
# by scripts/assistants-seed.sh).
