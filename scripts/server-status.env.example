# Copy to server-status.env (gitignored) to enable the Open WebUI status banner.
#   cp server-status.env.example server-status.env  &&  edit  &&  restart the service
#
# Create an admin API key in Open WebUI: Settings > Account > API Keys.
# When OWUI_API_KEY is set, the status service pushes a live banner to the top of
# the OWUI UI (visible on the blank new-chat screen, before typing).

OWUI_API_KEY=
# Optional overrides (defaults shown):
# OWUI_BANNER_URL=http://127.0.0.1:3000/api/v1/configs/banners
# OWUI_CONFIG_EXPORT_URL=http://127.0.0.1:3000/api/v1/configs/export
# OWUI_BANNER_INTERVAL=30
# OWUI_BANNER_ID=server-status
# OWUI_BANNER_TYPE=info
# OWUI_BANNER_DISMISSIBLE=false

# --- Fast-model keeper --------------------------------------------------------
# Re-warm `fast` on the P100 whenever its slot is empty (e.g. after a llama-swap
# restart, or after fast-uncensored's ttl expires). Enabled by default; it never
# evicts fast-uncensored while that is loaded. Defaults shown:
# FAST_KEEPER_ENABLED=true
# FAST_KEEP_MODEL=fast
# FAST_KEEP_ALT=fast-uncensored
# FAST_KEEPER_INTERVAL=60

# --- Host stats ---------------------------------------------------------------
# Comma-separated filesystems to report disk usage for (default "/"). Add mounts
# if models/data live on a separate disk, e.g. STATUS_DISK_PATHS=/,/mnt/data
# STATUS_DISK_PATHS=/

# --- Quiet hours (deep-idle window) -------------------------------------------
# During the window the daily models are unloaded and the ComfyUI units are
# stopped so the V100s fall out of P0 to true cold idle (~73 W vs ~103 W). Any
# client LLM request still wakes llama-swap on demand; when that happens ComfyUI
# is restarted so the box is fully ready, then it re-idles after the box has been
# quiet for QUIET_ACTIVITY_GRACE seconds. At window end the daily set is re-warmed.
#
# Requires the scoped sudoers rule so this service can stop/start ComfyUI:
#   sudo install -m 0440 -o root -g root \
#     /srv/ai/scripts/server-status-comfyui.sudoers \
#     /etc/sudoers.d/server-status-comfyui
#
# Disabled by default; set QUIET_HOURS_ENABLED=true to turn it on. Defaults shown:
# QUIET_HOURS_ENABLED=false
# QUIET_HOURS_START=02:00
# QUIET_HOURS_END=09:00
# QUIET_CHECK_INTERVAL=30
# QUIET_ACTIVITY_GRACE=600
# QUIET_UNLOAD_MODELS=true
# QUIET_STOP_COMFYUI=true
# QUIET_COMFYUI_UNITS=comfyui-open,comfyui-secure
# QUIET_SYSTEMCTL=sudo systemctl
# QUIET_WARM_ON_EXIT=coding,chat
# QUIET_ACTIVE_SM_PCT=5     # re-idle once max GPU SM util stays below this %% for the grace period
