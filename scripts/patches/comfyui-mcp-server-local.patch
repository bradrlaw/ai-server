From 2a15fde5a672aac0362e35d8e2055df7e05ebfb6 Mon Sep 17 00:00:00 2001
From: brad <brad@localhost>
Date: Sun, 5 Jul 2026 04:19:34 +0000
Subject: [PATCH 4/4] Drop the placeholder-host example from tool description

Models copied the literal 'host' from the example URL, producing unreachable
http://host:8188/... image links. Instruct to use the exact URL from the 'markdown'
field instead of showing a fake example URL.
---
 managers/workflow_manager.py | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/managers/workflow_manager.py b/managers/workflow_manager.py
index 427995e..6ebdb17 100644
--- a/managers/workflow_manager.py
+++ b/managers/workflow_manager.py
@@ -454,11 +454,11 @@ class WorkflowManager:
         return (
             f"Execute the '{readable}' ComfyUI workflow. "
             "IMPORTANT — to show the image to the user, your reply MUST contain the "
-            "result's 'markdown' field copied EXACTLY as-is. It begins with '![' and "
-            "the leading exclamation mark is REQUIRED to embed the image inline. Do NOT "
-            "rewrite it as a plain '[link](...)', do NOT drop the '!', and do NOT replace "
-            "the URL. Example of a correct reply line: "
-            "![image](http://host:8188/view?filename=out.png&type=output)"
+            "result's 'markdown' field copied EXACTLY and VERBATIM. It begins with '![' "
+            "and the leading exclamation mark is REQUIRED to embed the image inline. Do "
+            "NOT rewrite it as a plain '[link](...)', do NOT drop the '!', and do NOT "
+            "change or invent the URL host/filename — use the exact URL from the "
+            "'markdown' field, which is already correct and reachable."
         )
 
     def _determine_namespace(self, workflow_id: str) -> str:
